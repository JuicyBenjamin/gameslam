model SlamComment {
  id              String   @id @default(uuid())
  parentCommentId String?
  authorId        String
  slamEntryId     String
  createdAt       DateTime @default(now())
  isDeleted       Boolean  @default(false)
  comment         String

  parentComment SlamComment?  @relation("SlamCommentThread", fields: [parentCommentId], references: [id])
  replies       SlamComment[] @relation("SlamCommentThread")
  author        User          @relation(fields: [authorId], references: [id])
  slamEntry     SlamEntry     @relation(fields: [slamEntryId], references: [id])

  @@map("slam_comment")
}
